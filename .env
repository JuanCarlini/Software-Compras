# Configuración del servidor
PORT=3000
NODE_ENV=development

# Configuración de la base de datos SQL Server
DB_SERVER=127.0.0.1
DB_NAME=master
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true
DB_WINDOWS_AUTH=true

# Configuración de JWT y Session
JWT_SECRET=carlini-sistema-secreto-jwt
SESSION_SECRET=carlini-sistema-secreto-session
JWT_EXPIRES_IN=1d

# Configuración de correo (para futuras implementaciones)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=user@example.com
# EMAIL_PASS=password
# EMAIL_FROM=no-reply@sistema-carlini.com